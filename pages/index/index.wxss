/* pages/login/login.wxss */
page {
    background-color: #fff9e6;
  }
  
  .container {
    display: flex;
    flex-direction: column;
    height: 100vh;
    position: relative;
    background: linear-gradient(135deg, #ffd966 0%, #ffc107 100%);
  }
  
  /* 顶部装饰 */
  .top-bg {
    height: 200rpx;
    background: rgba(255,255,240,0.3);
    border-radius: 0 0 50% 50%;
    margin-top: 0;
  }
  
  /* 应用信息区域 */
  .app-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 60rpx 0;
  }
  
  .app-name {
    font-size: 64rpx;
    font-weight: bold;
    color: #fff;
    text-shadow: 2rpx 2rpx 4rpx rgba(0,0,0,0.1);
    margin-bottom: 20rpx;
  }
  
  .app-desc {
    font-size: 28rpx;
    color: #fff9e6;
    letter-spacing: 2rpx;
  }
  
  /* 按钮区域 */
  .btn-group {
    padding: 0 60rpx 100rpx;
  }
  
  .role-btn {
    width: 100%;
    height: 200rpx;
    background: white;
    border-radius: 48rpx;
    box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.1);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    margin-bottom: 40rpx;
    transition: all 0.3s ease;
  }
  
  .role-btn::after {
    border: none;
  }
  
  .role-btn:active {
    transform: scale(0.98);
    opacity: 0.9;
  }
  
  .btn-emoji {
    font-size: 56rpx;
    margin-bottom: 12rpx;
  }
  
  .btn-text {
    font-size: 36rpx;
    font-weight: bold;
    color: #333;
    margin-bottom: 8rpx;
  }
  
  .btn-desc {
    font-size: 24rpx;
    color: #999;
  }
  
  .user-btn {
    background: #fff;
    border-left: 12rpx solid #ffb347;
  }
  
  .repairer-btn {
    background: #fff;
    border-left: 12rpx solid #ff9800;
  }
  
  /* 底部提示 */
  .footer {
    text-align: center;
    padding: 40rpx 0 60rpx;
    font-size: 24rpx;
    color: rgba(255,255,240,0.9);
  }