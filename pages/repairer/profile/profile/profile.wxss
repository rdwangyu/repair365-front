page {
  background: #EEF4FB;
  font-family: 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: #1E293B;
}

.page-wrap {
  min-height: 100vh;
  box-sizing: border-box;
}

/* ─── 状态页 ─── */
.state-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  gap: 20rpx;
}

.spinner {
  width: 52rpx;
  height: 52rpx;
  border: 5rpx solid #C8DFF5;
  border-top-color: #4A9ED6;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.state-msg {
  font-size: 26rpx;
  color: #94A3B8;
}

.error-emoji {
  font-size: 72rpx;
}

.retry-btn {
  margin-top: 8rpx;
  padding: 16rpx 52rpx;
  background: #4A9ED6;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

/* ─── Header ─── */
.page-header {
  background: #fff;
  padding: 48rpx 32rpx 36rpx;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 28rpx;
  border-bottom: 1rpx solid #E2ECF6;
}

/* 左：头像 + 状态 */
.header-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  flex-shrink: 0;
}

.avatar-wrap {
  position: relative;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #C8DFF5;
  display: block;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #C8DFF5, #A8CBEE);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #C8DFF5;
}

.avatar-initial {
  font-size: 48rpx;
  font-weight: 700;
  color: #2479B5;
}

/* 账号状态胶囊，在头像正下方 */
.status-pill {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 16rpx;
  border-radius: 40rpx;
  font-size: 22rpx;
  font-weight: 600;
  white-space: nowrap;
}

.status-pill-0 {
  background: #E0EFFA;
  color: #1D72AA;
}

.status-pill-1 {
  background: #FEF3C7;
  color: #B45309;
}

.status-pill-2 {
  background: #FEE2E2;
  color: #B91C1C;
}

.status-pill-3 {
  background: #F1F5F9;
  color: #64748B;
}

.status-dot-sm {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.status-dot-sm-0 {
  background: #4A9ED6;
}

.status-dot-sm-1 {
  background: #F59E0B;
}

.status-dot-sm-2 {
  background: #EF4444;
}

.status-dot-sm-3 {
  background: #94A3B8;
}

/* 右：名字 + 元信息 */
.header-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding-top: 4rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #0F172A;
  letter-spacing: 0.5rpx;
}

.meta-row {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}

.meta-icon {
  font-size: 22rpx;
  line-height: 1.6;
  opacity: 0.6;
  flex-shrink: 0;
}

.meta-text {
  font-size: 24rpx;
  color: #64748B;
  line-height: 1.6;
}

.meta-addr {
  flex: 1;
  line-height: 1.6;
}

.grade-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 4rpx;
}

.stars {
  font-size: 26rpx;
  color: #F59E0B;
  letter-spacing: 2rpx;
}

.grade-num {
  font-size: 26rpx;
  font-weight: 700;
  color: #F59E0B;
}

.level-pill {
  padding: 2rpx 14rpx;
  background: #E0EFFA;
  border-radius: 20rpx;
}

.level-pill text {
  font-size: 22rpx;
  font-weight: 600;
  color: #2479B5;
}

/* ─── 统计栏 ─── */
.stats-row {
  display: flex;
  align-items: center;
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 20rpx;
  padding: 28rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(74, 158, 214, 0.08);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stat-sep {
  width: 1rpx;
  height: 44rpx;
  background: #E2ECF6;
}

.stat-val {
  font-size: 32rpx;
  font-weight: 700;
  color: #1E293B;
  line-height: 1;
}

.stat-val.amber {
  color: #F59E0B;
}

.stat-val.blue {
  color: #2479B5;
}

.stat-label {
  font-size: 20rpx;
  color: #94A3B8;
}

/* ─── 内容区 ─── */
.content-area {
  padding: 0 24rpx;
}

/* ─── 通用卡片 ─── */
.card {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(74, 158, 214, 0.07);
}

.card-title-row {
  padding: 22rpx 28rpx 14rpx;
  border-bottom: 1rpx solid #EEF4FB;
}

.card-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #2479B5;
  letter-spacing: 0.5rpx;
}

.divider {
  height: 1rpx;
  background: #F4F8FD;
  margin: 0 28rpx;
}

.field-row {
  display: flex;
  align-items: center;
  padding: 22rpx 28rpx;
}

.field-row.align-top {
  align-items: flex-start;
}

.field-label {
  font-size: 26rpx;
  color: #94A3B8;
  width: 140rpx;
  flex-shrink: 0;
}

.field-value {
  font-size: 26rpx;
  color: #334155;
  flex: 1;
}

.field-value.address {
  line-height: 1.7;
}

.field-value.muted {
  color: #CBD5E1;
}

/* 性别 */
.gender-tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 20rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.male {
  background: #E0EFFA;
  color: #1D72AA;
}

.female {
  background: #FCE7F3;
  color: #9D174D;
}

/* 行内评分 */
.inline-grade {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.stars-sm {
  font-size: 24rpx;
  color: #F59E0B;
  letter-spacing: 2rpx;
}

.grade-num-sm {
  font-size: 24rpx;
  font-weight: 700;
  color: #F59E0B;
}

/* 等级 */
.level-tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 18rpx;
  background: #E0EFFA;
  border-radius: 20rpx;
}

.level-tag text {
  font-size: 24rpx;
  font-weight: 600;
  color: #2479B5;
}

/* ─── 营业执照一行 ─── */
.license-row {
  cursor: pointer;
}

.license-entry {
  display: flex;
  align-items: center;
  flex: 1;
  gap: 14rpx;
}

.license-thumb {
  width: 72rpx;
  height: 52rpx;
  border-radius: 8rpx;
  border: 1rpx solid #C8DFF5;
  background: #EEF4FB;
  flex-shrink: 0;
}

.license-hint {
  flex: 1;
  font-size: 24rpx;
  color: #64748B;
}

.license-arrow {
  font-size: 36rpx;
  color: #C8DFF5;
  font-weight: 300;
  line-height: 1;
}

/* ─── 底部客服按钮（低调风格）─── */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.96);
  padding: 14rpx 32rpx;
  padding-bottom: calc(14rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #E2ECF6;
  z-index: 99;
  box-sizing: border-box;
  backdrop-filter: blur(8px);
}

.btn-contact {
  width: 100%;
  height: 80rpx;
  border-radius: 16rpx;
  /* 低调：浅蓝描边，不填满 */
  background: #fff !important;
  color: #2479B5 !important;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border: 2rpx solid #A8CBEE !important;
  box-shadow: none;
  letter-spacing: 0.5rpx;
  line-height: 1;
}

.btn-contact::after {
  border: none;
}

.btn-icon {
  font-size: 30rpx;
}

.btn-text {
  color: #2479B5;
  font-size: 28rpx;
}

.tabbar-hide {
  display: none;
}