/* pages/masterDetail/masterDetail.wxss */

/* ── 全局 ── */
page {
    background: #E3F2FD;
    font-family: 'PingFang SC', 'Helvetica Neue', sans-serif;
  }
  
  .page-wrap {
    min-height: 100vh;
    padding-bottom: 140rpx;
  }
  
  /* ── 状态页 ── */
  .state-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    gap: 24rpx;
  }
  .spinner {
    width: 64rpx;
    height: 64rpx;
    border: 6rpx solid rgba(21,101,192,0.25);
    border-top-color: #1565C0;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .state-msg {
    font-size: 28rpx;
    color: #546E7A;
  }
  .error-icon {
    width: 100rpx;
    height: 100rpx;
  }
  .retry-btn {
    margin-top: 12rpx;
    padding: 16rpx 48rpx;
    background: #1565C0;
    color: #fff;
    border-radius: 40rpx;
    font-size: 28rpx;
  }
  
  /* ── Header ── */
  .page-header {
    background: linear-gradient(160deg, #0A2463 0%, #1565C0 60%, #1E88E5 100%);
    padding: 80rpx 40rpx 100rpx;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12rpx;
    position: relative;
    overflow: hidden;
  }
  .page-header::before {
    content: '';
    position: absolute;
    top: -80rpx; right: -80rpx;
    width: 320rpx; height: 320rpx;
    border-radius: 50%;
    background: rgba(255,255,255,0.06);
  }
  .page-header::after {
    content: '';
    position: absolute;
    bottom: 30rpx; left: -60rpx;
    width: 240rpx; height: 240rpx;
    border-radius: 50%;
    background: rgba(255,255,255,0.04);
  }
  
  /* 头像 */
  .avatar-wrap {
    position: relative;
    margin-bottom: 12rpx;
  }
  .avatar {
    width: 160rpx;
    height: 160rpx;
    border-radius: 50%;
    border: 6rpx solid rgba(255,255,255,0.65);
    display: block;
    background: #BBDEFB;
  }
  .avatar-placeholder {
    width: 160rpx;
    height: 160rpx;
    border-radius: 50%;
    border: 6rpx solid rgba(255,255,255,0.65);
    background: linear-gradient(135deg, #1565C0, #0D47A1);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .avatar-icon {
    font-size: 72rpx;
    opacity: 0.75;
  }
  
  /* 状态角标 */
  .status-badge {
    position: absolute;
    bottom: 6rpx; right: -10rpx;
    padding: 4rpx 14rpx;
    border-radius: 20rpx;
    font-size: 20rpx;
    font-weight: 600;
    border: 4rpx solid white;
    white-space: nowrap;
  }
  .status-0 { background: #42A5F5; color: #fff; }
  .status-1 { background: #FFB300; color: #fff; }
  .status-2 { background: #E53935; color: #fff; }
  .status-3 { background: #90A4AE; color: #fff; }
  
  .user-name {
    font-size: 40rpx;
    font-weight: 700;
    color: #fff;
    letter-spacing: 1rpx;
    text-shadow: 0 2rpx 12rpx rgba(0,0,0,0.2);
  }
  .user-phone {
    font-size: 26rpx;
    color: rgba(255,255,255,0.72);
    letter-spacing: 2rpx;
  }
  
  /* ── 统计栏 ── */
  .stats-row {
    display: flex;
    background: rgba(255,255,255,0.18);
    backdrop-filter: blur(12px);
    margin: -40rpx 24rpx 0;
    border-radius: 24rpx;
    padding: 28rpx 0;
    border: 1rpx solid rgba(255,255,255,0.25);
    position: relative;
    z-index: 10;
    box-shadow: 0 8rpx 32rpx rgba(21,101,192,0.15);
  }
  .stat-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6rpx;
  }
  .stat-divider {
    border-left: 1rpx solid rgba(255,255,255,0.25);
  }
  .stat-val {
    font-size: 36rpx;
    font-weight: 700;
    color: #fff;
    line-height: 1.2;
  }
  .stat-val.gold, .gold {
    color: #FFD54F;
  }
  .stat-label {
    font-size: 20rpx;
    color: rgba(255,255,255,0.65);
  }
  
  /* ── 内容区 ── */
  .content-area {
    margin-top: 24rpx;
    padding: 0 24rpx;
  }
  
  /* ── 营业执照 ── */
  .license-card {
    background: #fff;
    border-radius: 24rpx;
    margin-bottom: 20rpx;
    overflow: hidden;
    border: 2rpx solid #BBDEFB;
    box-shadow: 0 4rpx 24rpx rgba(21,101,192,0.10);
  }
  .license-header {
    background: linear-gradient(90deg, #1565C0, #0D47A1);
    padding: 24rpx 28rpx;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .license-title {
    font-size: 28rpx;
    font-weight: 700;
    color: #fff;
    letter-spacing: 1rpx;
  }
  .license-badge {
    background: #FFB300;
    color: #fff;
    font-size: 20rpx;
    font-weight: 700;
    padding: 4rpx 16rpx;
    border-radius: 20rpx;
    letter-spacing: 1rpx;
  }
  .license-body {
    padding: 24rpx;
    position: relative;
  }
  .license-img {
    width: 100%;
    border-radius: 16rpx;
    display: block;
    border: 1rpx solid #BBDEFB;
  }
  .license-placeholder {
    width: 100%;
    min-height: 240rpx;
    border-radius: 16rpx;
    background: linear-gradient(135deg, #E3F2FD, #BBDEFB);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12rpx;
    border: 2rpx dashed #90CAF9;
  }
  .license-ph-icon { font-size: 72rpx; opacity: 0.5; }
  .license-ph-text { font-size: 26rpx; color: #1565C0; opacity: 0.6; }
  
  .zoom-hint {
    position: absolute;
    bottom: 40rpx; right: 44rpx;
    background: rgba(21,101,192,0.72);
    padding: 8rpx 20rpx;
    border-radius: 40rpx;
  }
  .zoom-text {
    font-size: 22rpx;
    color: #fff;
  }
  
  /* ── 通用卡片 ── */
  .card {
    background: #fff;
    border-radius: 24rpx;
    box-shadow: 0 4rpx 24rpx rgba(21,101,192,0.08);
    margin-bottom: 20rpx;
    overflow: hidden;
  }
  .card-header {
    padding: 24rpx 28rpx 16rpx;
    display: flex;
    align-items: center;
    gap: 12rpx;
    border-bottom: 1rpx solid #EEF2F7;
  }
  .card-header-bar {
    width: 6rpx;
    height: 32rpx;
    border-radius: 4rpx;
    background: linear-gradient(180deg, #1565C0, #0D47A1);
  }
  .card-title {
    font-size: 28rpx;
    font-weight: 700;
    color: #1A237E;
    letter-spacing: 0.5rpx;
  }
  
  /* 字段行 */
  .field-row {
    display: flex;
    align-items: flex-start;
    padding: 22rpx 28rpx;
    border-bottom: 1rpx solid #F5F7FA;
  }
  .field-row-last {
    border-bottom: none;
  }
  .field-label {
    font-size: 26rpx;
    color: #90A4AE;
    width: 140rpx;
    flex-shrink: 0;
    padding-top: 2rpx;
  }
  .field-value {
    font-size: 26rpx;
    color: #455A64;
    flex: 1;
    line-height: 1.6;
  }
  .field-value.bold {
    font-weight: 600;
    color: #1A237E;
  }
  .address-val {
    font-size: 26rpx;
    color: #455A64;
    line-height: 1.7;
    flex: 1;
  }
  
  /* 性别标签 */
  .gender-tag {
    display: inline-flex;
    align-items: center;
    padding: 4rpx 20rpx;
    border-radius: 40rpx;
    font-size: 24rpx;
    font-weight: 500;
  }
  .gender-male { background: #E3F2FD; color: #1565C0; }
  .gender-female { background: #FCE4EC; color: #C2185B; }
  
  /* 评分 */
  .grade-wrap {
    display: flex;
    align-items: center;
    gap: 10rpx;
  }
  .stars {
    font-size: 28rpx;
    color: #FFB300;
    letter-spacing: 2rpx;
  }
  .grade-num {
    font-size: 30rpx;
    font-weight: 700;
    color: #FFB300;
  }
  
  /* 等级 */
  .level-badge {
    display: inline-flex;
    align-items: center;
    padding: 6rpx 20rpx;
    background: linear-gradient(90deg, #1565C0, #0D47A1);
    border-radius: 40rpx;
  }
  .level-badge text {
    font-size: 24rpx;
    font-weight: 600;
    color: #fff;
  }
  
  /* 行内状态 */
  .status-inline {
    display: inline-flex;
    align-items: center;
    padding: 4rpx 20rpx;
    border-radius: 40rpx;
    font-size: 24rpx;
    font-weight: 600;
  }
  /* 复用同色 */
  .status-inline.status-0 { background: #E3F2FD; color: #1565C0; }
  .status-inline.status-1 { background: #FFF8E1; color: #F57F17; }
  .status-inline.status-2 { background: #FFEBEE; color: #C62828; }
  .status-inline.status-3 { background: #ECEFF1; color: #546E7A; }
  
  /* ── 底部按钮 ── */
  .bottom-bar {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    background: #fff;
    padding: 16rpx 32rpx;
    padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
    box-shadow: 0 -2rpx 24rpx rgba(21,101,192,0.12);
    z-index: 100;
  }
  .btn-contact {
    width: 100%;
    height: 96rpx;
    border-radius: 48rpx;
    background: linear-gradient(90deg, #1565C0, #0D47A1) !important;
    color: #fff !important;
    font-size: 30rpx;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14rpx;
    border: none;
    box-shadow: 0 8rpx 32rpx rgba(21,101,192,0.35);
    letter-spacing: 1rpx;
    line-height: 1;
  }
  .btn-contact::after { border: none; }
  .btn-icon { font-size: 36rpx; }
  .btn-text { color: #fff; font-size: 30rpx; font-weight: 600; }
  