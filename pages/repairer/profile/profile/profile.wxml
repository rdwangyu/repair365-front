<view class="page-wrap" style="padding-bottom: {{bottomPadding}}px;">

<!-- 加载中 -->
<view class="state-center" wx:if="{{loading}}">
  <view class="spinner"></view>
  <text class="state-msg">正在加载…</text>
</view>

<!-- 错误 -->
<view class="state-center" wx:elif="{{error}}">
  <text class="error-emoji">😕</text>
  <text class="state-msg">{{errorMsg}}</text>
  <view class="retry-btn" bindtap="loadData">重新加载</view>
</view>

<!-- 主内容 -->
<block wx:elif="{{userInfo}}">

  <!-- Header：左头像+状态，右信息 -->
  <view class="page-header">
    <view class="header-left">
      <view class="avatar-wrap">
        <image
          wx:if="{{userInfo.avatar}}"
          class="avatar"
          src="{{userInfo.avatar}}"
          mode="aspectFill"
        />
        <view wx:else class="avatar-placeholder">
          <text class="avatar-initial">{{userInfo.fullname[0]}}</text>
        </view>
      </view>
      <!-- 账号状态：头像正下方，醒目 -->
      <view class="status-pill status-pill-{{userInfo.account_status}}">
        <view class="status-dot-sm status-dot-sm-{{userInfo.account_status}}"></view>
        <text>{{statusMap[userInfo.account_status]}}</text>
      </view>
    </view>

    <view class="header-right">
      <text class="user-name">{{userInfo.fullname}}</text>
      <view class="meta-row">
        <text class="meta-icon">📱</text>
        <text class="meta-text">{{userInfo.phone}}</text>
      </view>
      <view class="meta-row">
        <text class="meta-icon">📍</text>
        <text class="meta-text meta-addr">{{userInfo.address || '暂无地址'}}</text>
      </view>
      <view class="grade-row">
        <text class="stars">{{stars}}</text>
        <text class="grade-num">{{userInfo.user_grade}}</text>
        <view class="level-pill"><text>Lv.{{userInfo.level || 0}}</text></view>
      </view>
    </view>
  </view>

  <!-- 统计栏 -->
  <view class="stats-row">
    <view class="stat-item">
      <text class="stat-val">{{userInfo.age}}</text>
      <text class="stat-label">年龄</text>
    </view>
    <view class="stat-sep"></view>
    <view class="stat-item">
      <text class="stat-val">{{userInfo.work_year}}</text>
      <text class="stat-label">工龄（年）</text>
    </view>
    <view class="stat-sep"></view>
    <view class="stat-item">
      <text class="stat-val amber">{{userInfo.user_grade}}</text>
      <text class="stat-label">综合评分</text>
    </view>
    <view class="stat-sep"></view>
    <view class="stat-item">
      <text class="stat-val blue">Lv.{{userInfo.level}}</text>
      <text class="stat-label">等级</text>
    </view>
  </view>

  <view class="content-area">

    <!-- 基本信息 -->
    <view class="card">
      <view class="card-title-row">
        <text class="card-title">基本信息</text>
      </view>
      <view class="field-row">
        <text class="field-label">性别</text>
        <view class="gender-tag {{userInfo.sex === 1 ? 'male' : 'female'}}">
          <text>{{userInfo.sex === 1 ? '♂ 男' : '♀ 女'}}</text>
        </view>
      </view>
      <view class="divider"></view>
      <view class="field-row">
        <text class="field-label">年龄</text>
        <text class="field-value">{{userInfo.age || '—'}} 岁</text>
      </view>
      <view class="divider"></view>
      <view class="field-row align-top">
        <text class="field-label">地址</text>
        <text class="field-value address">{{userInfo.address || '—'}}</text>
      </view>
    </view>

    <!-- 职业信息 -->
    <view class="card">
      <view class="card-title-row">
        <text class="card-title">职业信息</text>
      </view>
      <view class="field-row">
        <text class="field-label">工作年限</text>
        <text class="field-value">{{userInfo.work_year || '—'}} 年</text>
      </view>
      <view class="divider"></view>
      <view class="field-row">
        <text class="field-label">综合评分</text>
        <view class="inline-grade">
          <text class="stars-sm">{{stars}}</text>
          <text class="grade-num-sm">{{userInfo.user_grade}}</text>
        </view>
      </view>
      <view class="divider"></view>
      <view class="field-row">
        <text class="field-label">师傅等级</text>
        <view class="level-tag"><text>Lv.{{userInfo.level || 0}}</text></view>
      </view>
      <view class="divider"></view>
      <!-- 营业执照：一行入口，缩略图 + 点击查看 -->
      <view class="field-row license-row" bindtap="previewLicense">
        <text class="field-label">营业执照</text>
        <view class="license-entry" wx:if="{{userInfo.business_license}}">
          <image class="license-thumb" src="{{userInfo.business_license}}" mode="aspectFill"/>
          <text class="license-hint">点击查看大图</text>
          <text class="license-arrow">›</text>
        </view>
        <view class="license-entry" wx:else>
          <text class="field-value muted">暂未上传</text>
        </view>
      </view>
    </view>

  </view>
</block>

<!-- 底部客服按钮，low-key 风格 -->
<view class="bottom-bar" style="bottom: {{tabbarHeight}}px;" wx:if="{{!loading && !error}}">
  <button class="btn-contact" bindtap="callService">
    <text class="btn-icon">📞</text>
    <text class="btn-text">联系客服</text>
  </button>
</view>

</view>

<custom-tabbar class="{{showTabbar ? '' : 'tabbar-hide'}}" role="repairer" current="profile" />
