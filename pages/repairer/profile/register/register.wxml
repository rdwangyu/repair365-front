<view class="page">

<!-- Header -->
<view class="header">
  <view class="header-badge">师傅端注册</view>
  <view class="header-title">成为认证师傅</view>
  <view class="header-sub">填写完整信息，等待平台审核认证</view>
</view>

<!-- Steps -->
<view class="steps">
  <view class="step done">
    <view class="step-dot">✓</view>
    <view class="step-label">微信授权</view>
  </view>
  <view class="step-line done-line"></view>
  <view class="step active">
    <view class="step-dot active-dot">2</view>
    <view class="step-label active-label">填写资料</view>
  </view>
  <view class="step-line"></view>
  <view class="step">
    <view class="step-dot">3</view>
    <view class="step-label">等待审核</view>
  </view>
</view>

<!-- 基本信息 -->
<view class="section-card">
  <view class="section-title">基本信息</view>

  <!-- 头像 -->
  <view class="avatar-row">
    <view class="avatar-box" bindtap="chooseAvatar">
      <image wx:if="{{form.avatar}}" class="avatar-img" src="{{form.avatar}}" mode="aspectFill"/>
      <view wx:else class="avatar-placeholder">
        <image class="upload-icon-img" src="/images/camera.png" mode="aspectFit"/>
        <text class="avatar-tip">上传头像</text>
      </view>
    </view>
    <view class="avatar-hint">
      <text class="avatar-hint-title">师傅头像</text>
      <text class="avatar-hint-sub">请上传清晰的正脸照片\n支持 JPG / PNG 格式</text>
    </view>
  </view>

  <!-- 姓名 -->
  <view class="field">
    <view class="field-label">真实姓名 <text class="required">*</text></view>
    <input class="field-input" placeholder="请输入您的真实姓名" value="{{form.fullname}}" bindinput="onInput" data-key="fullname" />
  </view>

  <!-- 年龄 + 工作年限 -->
  <view class="field-row">
    <view class="field field-half">
      <view class="field-label">年龄 <text class="required">*</text></view>
      <input class="field-input" type="number" placeholder="周岁" value="{{form.age}}" bindinput="onInput" data-key="age" />
    </view>
    <view class="field field-half">
      <view class="field-label">工作年限 <text class="required">*</text></view>
      <input class="field-input" type="number" placeholder="年" value="{{form.work_year}}" bindinput="onInput" data-key="work_year" />
    </view>
  </view>

  <!-- 性别 -->
  <view class="field">
    <view class="field-label">性别 <text class="required">*</text></view>
    <view class="radio-group">
      <view class="radio-btn {{form.sex === 1 ? 'radio-selected' : ''}}" bindtap="selectSex" data-val="1">
        <text>👨</text><text> 男</text>
      </view>
      <view class="radio-btn {{form.sex === 2 ? 'radio-selected' : ''}}" bindtap="selectSex" data-val="2">
        <text>👩</text><text> 女</text>
      </view>
    </view>
  </view>

  <!-- 手机 -->
  <view class="field">
    <view class="field-label">手机号码 <text class="required">*</text></view>
    <input class="field-input" type="number" placeholder="请输入手机号码" maxlength="11" value="{{form.phone}}" bindinput="onInput" data-key="phone" />
  </view>

  <!-- 地址 -->
  <view class="field">
    <view class="field-label">服务地址 <text class="required">*</text></view>
    <textarea class="field-textarea" placeholder="请填写详细地址，如：上海市浦东新区XX街道XX号" value="{{form.address}}" bindinput="onInput" data-key="address" auto-height />
  </view>
</view>

<!-- 身份证 -->
<view class="section-card">
  <view class="section-title">身份证照片</view>
  <view class="id-grid">
    <view class="upload-box" bindtap="chooseImage" data-key="identity_card_0">
      <image wx:if="{{form.identity_card_0}}" class="upload-preview" src="{{form.identity_card_0}}" mode="aspectFill"/>
      <view wx:else class="upload-inner">
        <text class="upload-plus">＋</text>
        <text class="upload-label">身份证正面</text>
        <text class="upload-sub">人像面</text>
      </view>
    </view>
    <view class="upload-box" bindtap="chooseImage" data-key="identity_card_1">
      <image wx:if="{{form.identity_card_1}}" class="upload-preview" src="{{form.identity_card_1}}" mode="aspectFill"/>
      <view wx:else class="upload-inner">
        <text class="upload-plus">＋</text>
        <text class="upload-label">身份证反面</text>
        <text class="upload-sub">国徽面</text>
      </view>
    </view>
  </view>
  <view class="tips-box">💡 请确保证件信息清晰可见，四角完整，光线均匀，不得遮挡任何信息。</view>
</view>

<!-- 营业执照 -->
<view class="section-card">
  <view class="section-title">营业执照</view>
  <view class="upload-single" bindtap="chooseImage" data-key="business_license">
    <view class="upload-single-left">
      <view class="upload-single-icon">
        <text class="upload-single-icon-text">📄</text>
      </view>
      <view>
        <view class="upload-single-title">
          {{form.business_license ? '已上传，点击重新选择' : '上传营业执照'}}
        </view>
        <view class="upload-single-sub">支持 JPG / PNG，文件不超过 5MB</view>
      </view>
    </view>
    <text class="arrow">›</text>
  </view>
  <image wx:if="{{form.business_license}}" class="license-preview" src="{{form.business_license}}" mode="aspectFit"/>
  <view class="tips-box">💡 如暂无营业执照，可先行提交，审核人员将与您联系确认。</view>
</view>

<!-- 底部占位 -->
<view class="bottom-placeholder"></view>

</view>

<!-- 底部提交 -->
<view class="bottom-bar">
<button class="submit-btn {{submitting ? 'submitting' : ''}}" bindtap="submitForm" disabled="{{submitting}}">
  <text>{{submitting ? '提交中...' : '提交审核'}}</text>
</button>
<view class="submit-hint">提交后将在 1-3 个工作日内完成审核</view>
</view>
