/* ===== 全局 ===== */
.page {
  background: #f0f7ff;
  min-height: 100vh;
  padding-bottom: 0;
}

/* ===== Header ===== */
.header {
  background: linear-gradient(135deg, #0a4fa6 0%, #1a6fd4 60%, #3b8fee 100%);
  padding: 60rpx 40rpx 50rpx;
  position: relative;
  overflow: hidden;
}
.header::before {
  content: '';
  position: absolute;
  top: -60rpx; right: -60rpx;
  width: 280rpx; height: 280rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.06);
}
.header-badge {
  display: inline-block;
  background: rgba(13,211,197,0.18);
  color: #0dd3c5;
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 4rpx;
  padding: 6rpx 20rpx;
  border-radius: 40rpx;
  border: 1rpx solid rgba(13,211,197,0.3);
  margin-bottom: 18rpx;
}
.header-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.2;
}
.header-sub {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: rgba(255,255,255,0.65);
}

/* ===== Steps ===== */
.steps {
  display: flex;
  align-items: center;
  padding: 36rpx 40rpx 20rpx;
  background: #f0f7ff;
}
.step {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.step-line {
  flex: 1;
  height: 2rpx;
  background: #ccdcee;
  margin-bottom: 32rpx;
}
.done-line {
  background: linear-gradient(90deg, #1a6fd4, #ccdcee);
}
.step-dot {
  width: 52rpx; height: 52rpx;
  border-radius: 50%;
  background: #fff;
  border: 3rpx solid #ccdcee;
  display: flex; align-items: center; justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  color: #8ba3bd;
}
.active-dot {
  background: #1a6fd4;
  border-color: #1a6fd4;
  color: #fff;
  box-shadow: 0 0 0 8rpx rgba(26,111,212,0.15);
}
.step.done .step-dot {
  background: #0a4fa6;
  border-color: #0a4fa6;
  color: #fff;
}
.step-label {
  margin-top: 10rpx;
  font-size: 20rpx;
  color: #8ba3bd;
}
.active-label {
  color: #1a6fd4;
  font-weight: 600;
}

/* ===== Section card ===== */
.section-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(10,79,166,0.06);
  border: 1rpx solid rgba(204,220,238,0.5);
}
.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0a4fa6;
  letter-spacing: 1rpx;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
}
.section-title::before {
  content: '';
  display: inline-block;
  width: 6rpx; height: 28rpx;
  background: linear-gradient(180deg, #1a6fd4, #0dd3c5);
  border-radius: 4rpx;
  margin-right: 14rpx;
}

/* ===== Avatar ===== */
.avatar-row {
  display: flex;
  align-items: center;
  gap: 28rpx;
  margin-bottom: 28rpx;
}
.avatar-box {
  width: 130rpx; height: 130rpx;
  border-radius: 50%;
  background: #f0f7ff;
  border: 3rpx dashed #3b8fee;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}
.avatar-img {
  width: 130rpx; height: 130rpx;
  border-radius: 50%;
}
.avatar-placeholder {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
}
.upload-icon-img {
  width: 44rpx; height: 44rpx;
  opacity: 0.5;
}
.avatar-tip {
  font-size: 20rpx;
  color: #3b8fee;
  margin-top: 8rpx;
  font-weight: 500;
}
.avatar-hint {
  display: flex; flex-direction: column; gap: 6rpx;
}
.avatar-hint-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0d1b2e;
}
.avatar-hint-sub {
  font-size: 22rpx;
  color: #4a6480;
  line-height: 1.7;
}

/* ===== Fields ===== */
.field {
  margin-bottom: 24rpx;
}
.field:last-child { margin-bottom: 0; }
.field-row {
  display: flex;
  gap: 18rpx;
  margin-bottom: 24rpx;
}
.field-half { flex: 1; }

.field-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #4a6480;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
}
.required {
  color: #e53e3e;
  font-size: 28rpx;
  margin-left: 4rpx;
  line-height: 1;
}
.field-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #ccdcee;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #0d1b2e;
  background: #fff;
  box-sizing: border-box;
}
.field-input:focus {
  border-color: #1a6fd4;
}
.field-textarea {
  width: 100%;
  min-height: 130rpx;
  border: 2rpx solid #ccdcee;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #0d1b2e;
  background: #fff;
  box-sizing: border-box;
  line-height: 1.6;
}

/* ===== Radio ===== */
.radio-group {
  display: flex;
  gap: 18rpx;
}
.radio-btn {
  flex: 1;
  height: 80rpx;
  border: 2rpx solid #ccdcee;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #4a6480;
  background: #fff;
}
.radio-selected {
  border-color: #1a6fd4;
  background: #e8f2ff;
  color: #1a6fd4;
  font-weight: 600;
}

/* ===== ID Upload ===== */
.id-grid {
  display: flex;
  gap: 18rpx;
  margin-bottom: 20rpx;
}
.upload-box {
  flex: 1;
  background: #f0f7ff;
  border: 2rpx dashed #3b8fee;
  border-radius: 20rpx;
  height: 170rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.upload-preview {
  width: 100%; height: 170rpx;
}
.upload-inner {
  display: flex; flex-direction: column;
  align-items: center; gap: 6rpx;
}
.upload-plus {
  font-size: 44rpx;
  color: #3b8fee;
  line-height: 1;
}
.upload-label {
  font-size: 24rpx;
  color: #1a6fd4;
  font-weight: 600;
}
.upload-sub {
  font-size: 20rpx;
  color: #8ba3bd;
}

/* ===== Business license ===== */
.upload-single {
  background: #f0f7ff;
  border: 2rpx dashed #3b8fee;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.upload-single-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.upload-single-icon {
  width: 80rpx; height: 80rpx;
  background: rgba(26,111,212,0.1);
  border-radius: 18rpx;
  display: flex; align-items: center; justify-content: center;
}
.upload-single-icon-text {
  font-size: 36rpx;
}
.upload-single-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0d1b2e;
  margin-bottom: 6rpx;
}
.upload-single-sub {
  font-size: 22rpx;
  color: #8ba3bd;
}
.arrow {
  font-size: 40rpx;
  color: #8ba3bd;
}
.license-preview {
  width: 100%;
  max-height: 300rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

/* ===== Tips ===== */
.tips-box {
  background: linear-gradient(135deg, #fff9e6, #fffdf0);
  border: 1rpx solid #f0d060;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 22rpx;
  color: #8a6a00;
  line-height: 1.8;
}

/* ===== Bottom ===== */
.bottom-placeholder {
  height: 160rpx;
}
.bottom-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255,255,255,0.96);
  border-top: 1rpx solid #e0ecf8;
}
.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #0a4fa6 0%, #1a6fd4 100%);
  border: none;
  border-radius: 24rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(10,79,166,0.3);
}
.submit-btn::after {
  border: none;
}
.submitting {
  background: linear-gradient(135deg, #1a6fd4, #3b8fee);
  opacity: 0.85;
}
.submit-hint {
  text-align: center;
  font-size: 22rpx;
  color: #8ba3bd;
  margin-top: 12rpx;
}
