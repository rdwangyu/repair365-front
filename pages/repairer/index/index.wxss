.page {
  height: 100vh;
  background: #f5f7fb;
}

/* 地图 */
.map {
  width: 100%;
  height: 45vh;
}

/* 浮层 */
.panel {
  position: relative;
  margin-top: -60rpx;
  background: #f5f7fb;
  border-top-left-radius: 30rpx;
  border-top-right-radius: 30rpx;
  padding: 30rpx;
}

/* 标题 */
.panel-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 25rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 10rpx 25rpx rgba(0,0,0,0.05);
}

/* 顶部 */
.card-top {
  display: flex;
  justify-content: space-between;
}

.order-no {
  font-weight: bold;
}

/* 状态 */
.status {
  background: #2A7BFF;
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

/* 描述 */
.desc {
  margin-top: 10rpx;
  color: #333;
}

/* 地址 */
.address {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #666;
}

/* 底部 */
.bottom {
  margin-top: 20rpx;
  display: flex;
  justify-content: space-between;
  color: #999;
  font-size: 22rpx;
}

.arrow {
  font-size: 30rpx;
}

/* 空 */
.empty {
  text-align: center;
  margin-top: 100rpx;
  color: #999;
}