<view class="page">

<!-- 状态 -->
<view class="status-card {{statusClass}}">
  <view class="status-text">{{statusText}}</view>
  <view class="order-no">订单号：{{order.order_number}}</view>
</view>

<!-- 信息 -->
<view class="card">

  <view class="row">
    <text class="label">客户</text>
    <text class="value">{{order.sponsor_detail.nickname}}</text>
  </view>

  <view class="row">
    <text class="label">电话</text>
    <view class="phone-box">
      <text class="value">{{order.contact_phone}}</text>
      <view class="call-btn"
        data-phone="{{order.contact_phone}}"
        bindtap="makePhoneCall">
        📞 联系
      </view>
    </view>
  </view>

  <!-- 地址加宽 -->
  <view class="row column">
    <text class="label">地址</text>
    <text class="value full">{{order.location}}</text>
  </view>

  <view class="row column">
    <text class="label">问题</text>
    <text class="value full">{{order.issue_description}}</text>
  </view>

  <view class="row column">
    <text class="label">备注</text>
    <text class="value full">{{order.comment}}</text>
  </view>

  <view class="row">
    <text class="label">预约</text>
    <text class="value">{{order.appointment_time}}</text>
  </view>

</view>

<!-- 横向进度 -->
<view class="card">
  <view class="title">订单进度</view>

  <view class="progress">
    <block wx:for="{{timeline}}" wx:key="index">
      <view class="step">
        <view class="circle {{item.active?'active':''}} {{item.current?'current':''}}"></view>
        <view class="step-text {{item.active?'active':''}}">
          {{item.text}}
        </view>
      </view>
    </block>
    <view class="progress-line"></view>
  </view>
</view>

<!-- 按钮 -->
<view class="footer">
  <block wx:for="{{actionButtons}}" wx:key="index">
    <button 
      class="action-btn {{item.type}}"
      data-action="{{item.action}}"
      bindtap="handleAction">
      {{item.text}}
    </button>
  </block>
</view>

</view>