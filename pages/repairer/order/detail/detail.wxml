<view class="container">

<!-- 顶部 -->
<view class="header">
  <view class="back" bindtap="goBack">← 返回</view>
  <view class="title">订单详情</view>
</view>

<!-- 状态卡片 -->
<view class="status-card">
  <view class="status-text">{{statusText}}</view>
  <view class="order-no">订单号：{{order.order_number}}</view>
</view>

<!-- 基本信息 -->
<view class="card">
  <view class="row">
    <text class="label">联系人</text>
    <text>{{order.sponsor.nickname}}</text>
  </view>
  <view class="row">
    <text class="label">电话</text>
    <text>{{order.contact_phone}}</text>
  </view>
  <view class="row">
    <text class="label">地址</text>
    <text>{{order.location}}</text>
  </view>
  <view class="row">
    <text class="label">预约时间</text>
    <text>{{order.appointment_time}}</text>
  </view>
</view>

<!-- 问题描述 -->
<view class="card">
  <view class="title2">问题描述</view>
  <view class="desc">{{order.issue_description}}</view>
</view>

<!-- 时间线 -->
<view class="card">
  <view class="title2">订单进度</view>

  <view class="timeline">
    <block wx:for="{{timeline}}" wx:key="index">
      <view class="timeline-item">
        <view class="dot"></view>
        <view class="content">
          <view class="time">{{item.time}}</view>
          <view class="text">{{item.text}}</view>
        </view>
      </view>
    </block>
  </view>
</view>

<!-- 底部按钮 -->
<view class="footer">
  <button class="action-btn" bindtap="handleAction">
    {{isAssigned ? '取消接单' : '接单'}}
  </button>
</view>

</view>