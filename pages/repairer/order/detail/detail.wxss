.page {
  background: #f5f7fb;
  min-height: 100vh;
  padding: 20rpx 20rpx 140rpx;
}

/* 顶部状态 */
/* 默认蓝色 */
.status-card {
  color: #fff;
  padding: 40rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

/* 蓝（待接单） */
.status-blue {
  background: linear-gradient(135deg, #2A7BFF, #5AA7FF);
}

/* 橙（进行中） */
.status-orange {
  background: linear-gradient(135deg, #FF8A00, #FFB347);
}

/* 紫（已到达） */
.status-purple {
  background: linear-gradient(135deg, #7B61FF, #A88BFF);
}

/* 绿（完成） */
.status-green {
  background: linear-gradient(135deg, #00B96B, #3ED598);
}

/* 红（未解决） */
.status-red {
  background: linear-gradient(135deg, #FF4D4F, #FF7A7A);
}

/* 灰（取消） */
.status-gray {
  background: linear-gradient(135deg, #999, #ccc);
}

.status-text {
  font-size: 36rpx;
  font-weight: bold;
}

.order-no {
  margin-top: 10rpx;
  font-size: 24rpx;
  opacity: 0.9;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

/* 行 */
.row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

/* 关键：纵向布局（解决地址窄） */
.row.column {
  flex-direction: column;
}

.label {
  color: #888;
  margin-bottom: 10rpx;
}

.value {
  color: #333;
  font-weight: 500;
}

/* 地址加宽 */
.value.full {
  width: 100%;
  word-break: break-all;
}

/* 电话 */
.phone-box {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.call-btn {
  padding: 8rpx 20rpx;
  background: rgba(42, 123, 255, 0.1);
  border-radius: 30rpx;
  color: #2A7BFF;
  font-size: 24rpx;
}

/* 标题 */
.title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

/* 横向进度 */
.progress {
  position: relative;
  display: flex;
  justify-content: space-between;
  padding-top: 40rpx;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.circle {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  background: #ddd;
  z-index: 2;
}

.circle.active {
  background: #2A7BFF;
}

.circle.current {
  transform: scale(1.6);
  box-shadow: 0 0 12rpx rgba(42, 123, 255, 0.6);
}

.step-text {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #999;
}

.step-text.active {
  color: #2A7BFF;
  font-weight: bold;
}

.progress-line {
  position: absolute;
  top: 50rpx;
  left: 0;
  right: 0;
  height: 4rpx;
  background: #eee;
}

/* 底部按钮 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 20rpx;
  background: #fff;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -5rpx 20rpx rgba(0, 0, 0, 0.05);
}

.action-btn {
  flex: 1;
  border-radius: 50rpx;
  font-size: 28rpx;
}

.action-btn.primary {
  background: #2A7BFF;
  color: #fff;
}

.action-btn.warn {
  background: #f5f5f5;
  color: #333;
}