.container {
    background: #f5f9ff;
    min-height: 100vh;
  }
  
  /* 头部 */
  .header {
    display: flex;
    align-items: center;
    padding: 20rpx;
    background: #4da3ff;
    color: white;
  }
  
  .back {
    font-size: 28rpx;
  }
  
  .title {
    flex: 1;
    text-align: center;
    font-size: 32rpx;
  }
  
  /* 状态卡片 */
  .status-card {
    background: #4da3ff;
    color: white;
    padding: 30rpx;
  }
  
  .status-text {
    font-size: 36rpx;
    font-weight: bold;
  }
  
  .order-no {
    margin-top: 10rpx;
    font-size: 24rpx;
  }
  
  /* 通用卡片 */
  .card {
    background: white;
    margin: 20rpx;
    padding: 20rpx;
    border-radius: 16rpx;
  }
  
  /* 行 */
  .row {
    display: flex;
    justify-content: space-between;
    margin-bottom: 16rpx;
  }
  
  .label {
    color: #888;
  }
  
  /* 描述 */
  .desc {
    color: #333;
    line-height: 1.6;
  }
  
  /* 时间线 */
  .timeline {
    margin-top: 20rpx;
  }
  
  .timeline-item {
    display: flex;
    position: relative;
    margin-bottom: 30rpx;
  }
  
  .dot {
    width: 16rpx;
    height: 16rpx;
    background: #4da3ff;
    border-radius: 50%;
    margin-right: 20rpx;
    margin-top: 8rpx;
  }
  
  .content .time {
    font-size: 24rpx;
    color: #999;
  }
  
  .content .text {
    font-size: 28rpx;
    color: #333;
  }
  
  /* 底部按钮 */
  .footer {
    position: fixed;
    bottom: 0;
    width: 100%;
    padding: 20rpx;
    background: white;
  }
  
  .action-btn {
    background: #4da3ff;
    color: white;
    border-radius: 50rpx;
  }