.container {
  padding: 20rpx;
  background: #f6f7f9;
  min-height: 100vh;
}

.status-card {
  background: #fff;
  padding: 40rpx;
  border-radius: 20rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.status {
  font-size: 40rpx;
  font-weight: bold;
}

.card {
  background: #fff;
  padding: 30rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.title {
  font-weight: bold;
  margin-bottom: 10rpx;
}