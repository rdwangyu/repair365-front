.container {
    padding: 20rpx;
    background: #f7faf9;
    min-height: 100vh;
}

/* 顶部 */
.header {
    display: flex;
    justify-content: space-between;
    padding: 20rpx;
}

.title {
    font-size: 36rpx;
    font-weight: bold;
}

.user {
    color: #999;
}

/* 一键报修（卡片风） */
.repair-card {
    margin: 60rpx auto;
    width: 90%;
    background: linear-gradient(135deg, #6e7975, #f3b839);
    border-radius: 30rpx;
    padding: 60rpx 0;
    text-align: center;
    color: #fff;
    box-shadow: 0 15rpx 30rpx rgba(0, 0, 0, 0.08);
}

.repair-icon {
    font-size: 60rpx;
}

.repair-text {
    font-size: 42rpx;
    margin-top: 10rpx;
}

/* 功能区 */
.grid {
    display: flex;
    justify-content: space-around;
}

.grid-item {
    width: 42%;
    background: #fff;
    padding: 40rpx 0;
    border-radius: 25rpx;
    text-align: center;
    box-shadow: 0 10rpx 20rpx rgba(0, 0, 0, 0.05);
}

.icon {
    font-size: 50rpx;
    display: block;
    margin-bottom: 10rpx;
}

/* 弹窗 */
.popup {
    position: fixed;
    inset: 0;
}

.mask {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
}

.drawer {
    position: absolute;
    bottom: 0;
    width: 100%;
    height: 85%;
    background: #fff;
    border-radius: 30rpx 30rpx 0 0;
}

/* 表单滚动 */
.drawer-body {
    height: calc(100% - 120rpx);
    padding: 30rpx;
    box-sizing: border-box;
}

.popup-title {
    font-size: 36rpx;
    font-weight: bold;
    margin-bottom: 20rpx;
}

/* 表单 */
.form-item {
    margin-bottom: 25rpx;
}

/* 固定城市 */
.city-fixed {
    display: inline-block;
    padding: 16rpx 30rpx;
    /* 比第二层稍微大一点 */
    border-radius: 30rpx;
    background: #f1f3f2;
    font-size: 26rpx;
    margin-bottom: 15rpx;
}

.city-fixed.active {
    background: #6ec1a5;
    color: #fff;
}

.label {
    font-size: 26rpx;
    color: #666;
    margin-bottom: 10rpx;
    display: block;
}

/* 输入 */
input,
textarea {
    width: 100%;
    background: #f5f7f6;
    padding: 20rpx;
    border-radius: 15rpx;
}

/* 选项 */
.options {
    display: flex;
    flex-wrap: wrap;
    gap: 12rpx;
}

/* 两排固定 */
.two-row .option {
    width: 30%;
}

/* 关键：防止文字溢出 */
.option {
    padding: 12rpx 0;
    text-align: center;
    background: #f1f3f2;
    border-radius: 30rpx;
    font-size: 24rpx;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

/* 选中 */
.option.active {
    background: #6ec1a5;
    color: #fff;
}

/* 固定按钮 */
.fixed-btn {
    position: absolute;
    bottom: 0;
    width: 100%;
    display: flex;
    gap: 20rpx;
    padding: 20rpx;
    background: #fff;
    border-top: 1rpx solid #eee;
}

.cancel {
    flex: 1;
    background: #eee;
}

.submit {
    flex: 1;
    background: #6ec1a5;
    color: #fff;
}

.tabbar-hide {
    display: none;
}