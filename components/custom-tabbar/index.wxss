.custom-tabbar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    height: 100rpx;
    background-color: #fff;
    border-top: 1px solid #e5e5e5;
    padding-bottom: env(safe-area-inset-bottom);
    z-index: 100;
  }
  
  .tabbar-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-size: 24rpx;
    color: #999;
  }
  
  .tabbar-item.active {
    color: #07c160;
  }
  
  .tabbar-item image {
    width: 48rpx;
    height: 48rpx;
    margin-bottom: 8rpx;
  }
  
  .tabbar-item text {
    font-size: 24rpx;
  }